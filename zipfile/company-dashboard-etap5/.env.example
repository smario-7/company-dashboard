# GitHub OAuth App Client ID (from Settings → Developer settings → OAuth Apps)
VITE_GITHUB_CLIENT_ID=your_client_id_here

# Repository details
VITE_GITHUB_OWNER=smario-7
VITE_GITHUB_REPO=company-dashboard

# Cloudflare Worker URL for GitHub OAuth proxy (required for production)
# See workers/github-proxy.js for setup instructions
# Example: https://github-proxy.yourname.workers.dev
VITE_GITHUB_PROXY_URL=https://github-proxy.YOUR_NAME.workers.dev
