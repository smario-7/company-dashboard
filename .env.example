# Repo GitHub (kontrola dostępu collaboratorów)
VITE_GITHUB_OWNER=smario-7
VITE_GITHUB_REPO=company-dashboard

# Supabase (Settings → API w dashboardzie)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GitHub OAuth (NIE wpisuj tutaj Client ID / Secret) ─────────────────────
# Logowanie idzie przez Supabase Auth. Credentials ustawiasz TYLKO w:
#   Supabase → Authentication → Providers → GitHub
# W polu Client ID musi być ID z GitHub OAuth App (np. Ov23li...),
# NIE nazwa aplikacji („Company Dashboard”).
#
# Po skopiowaniu tego pliku do .env.local uruchom:
#   npm run oauth:setup   — wypisze dokładne URL-e do wklejenia
#   npm run oauth:verify  — sprawdzi czy Supabase ma poprawny client_id
#
# Supabase → Authentication → Providers → GitHub:
#   włącz "Save provider refresh token" (jeśli dostępne), żeby token GitHub
#   był dostępny po powrocie z OAuth (provider_token w sesji).
