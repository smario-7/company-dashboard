{
  "openapi": "3.0.3",
  "info": {
    "title": "Company Dashboard API (sample)",
    "version": "0.1.0",
    "description": "Demo contract for vault JSON preview."
  },
  "paths": {
    "/projects": {
      "get": {
        "summary": "List projects",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Project" }
                }
              }
            }
          }
        }
      }
    },
    "/boards/{boardId}/cards": {
      "post": {
        "summary": "Create card",
        "parameters": [
          {
            "name": "boardId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "slug": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
